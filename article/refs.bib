@article{egeland2025cosmicbluff,
  title = {The `{{Cosmic Bluff}}' {{Revisited}}: {{Extended Nuclear Deterrence}} in the {{US}}--{{Norway Alliance}}},
  shorttitle = {The `{{Cosmic Bluff}}' {{Revisited}}},
  author = {Egeland, Kj{\o}lv},
  year = 2025,
  month = jan,
  journal = {Cold War History},
  volume = {25},
  number = {1},
  pages = {43--66},
  publisher = {Routledge},
  issn = {1468-2745},
  doi = {10.1080/14682745.2024.2352531},
  url = {https://doi.org/10.1080/14682745.2024.2352531},
  urldate = {2025-11-30},
  abstract = {What is the point of a nuclear umbrella? Conventional wisdom suggests that explicit nuclear security guarantees provide junior allies with credible security, facilitating regional stability and nuclear non-proliferation. Yet this is not the only possible reason to maintain a nuclear umbrella. Reassessing the history and politics of nuclear alignment through a case study of the US--Norway alliance, I find that nuclear umbrellas have endured, and can do so, in cases where both the security patron and client believe the arrangement to lack military credibility.},
  pmid = {39844820},
}

@article{eggers2014electoralsecurity,
  title = {Electoral {{Security}} as a {{Determinant}} of {{Legislator Activity}}, 1832--1918: {{New Data}} and {{Methods}} for {{Analyzing British Political Development}}},
  shorttitle = {Electoral {{Security}} as a {{Determinant}} of {{Legislator Activity}}, 1832--1918},
  author = {Eggers, Andrew C. and Spirling, Arthur},
  year = 2014,
  journal = {Legislative Studies Quarterly},
  volume = {39},
  number = {4},
  pages = {593--620},
  issn = {1939-9162},
  doi = {10.1111/lsq.12059},
  url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/lsq.12059},
  urldate = {2026-01-22},
  abstract = {We consider the relationship between a Member of Parliament's electoral environment and his strategic choice of legislative activities between the First and Fourth Reform Acts in Britain. We argue that voters and party institutions put cross-cutting pressures on members during this time, and that legislators calibrated their behavior in accordance with the marginality of their seat. We gather a massive new dataset documenting MPs' biographical information, electoral records, roll calls, and speeches. The extent of MPs' speech making and voting (our measures of legislative activity) vary with electoral security in ways consistent with our theoretical priors for Westminster systems.},
  copyright = {\copyright{} 2014 The Comparative Legislative Research Center of The University of Iowa},
  langid = {english},
  language = {en},
}

